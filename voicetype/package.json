{
  "name": "echo",
  "productName": "Echo",
  "version": "1.0.0",
  "author": "Aamir Azmi",
  "description": "Voice dictation for Windows: hold a hotkey, speak, and the transcript is typed into the focused app.",
  "license": "UNLICENSED",
  "main": ".vite/build/main.js",
  "scripts": {
    "start": "node scripts/dev-supervisor.cjs",
    "start:forge": "electron-forge start",
    "verify:release-assets": "node scripts/verify-release-assets.cjs",
    "package": "npm run verify:release-assets && electron-forge package",
    "make": "npm run verify:release-assets && electron-forge make",
    "publish": "npm run verify:release-assets && electron-forge publish",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint src/ --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fontsource/figtree": "^5.2.10",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "better-sqlite3": "^11.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-squirrel-startup": "^1.0.1",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.3.9",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.453.0",
    "openai": "^4.71.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.6.1",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron-forge/publisher-github": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@fontsource/cormorant": "^5.2.8",
    "@fontsource/playfair-display": "^5.2.8",
    "@types/better-sqlite3": "^7.6.11",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "autoprefixer": "^10.4.20",
    "electron": "^35.7.5",
    "electron-reloader": "^1.2.3",
    "eslint": "^9.16.0",
    "postcss": "^8.4.47",
    "tailwindcss": "3.4.14",
    "ts-node": "^10.9.2",
    "typescript": "~5.6.3",
    "vite": "^6.4.1",
    "vitest": "^3.1.1"
  }
}
