# Echo cloud sync — copy this file to `.env` and fill in real values from
# your Supabase project dashboard. The .env file is git-ignored so secrets
# never ship to GitHub. These values are baked into main.js at build time
# (Supabase anon keys are safe to embed in clients — RLS on the database
# enforces per-user access control).

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Optional: where Supabase should redirect OAuth flows back to. We use a
# custom deep link so the user lands back inside Echo, not the browser.
# Leave as-is unless you've changed the protocol scheme in main.
VITE_SUPABASE_REDIRECT_URL=echo://auth-callback
